<Window x:Class="CarharingApp.Views.ApiPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarharingApp.Views"
        mc:Ignorable="d"
        Title="ApiPage" Height="650" Width="500"
        Background="AliceBlue">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <TextBlock Grid.Row="0" Text="API"
                   HorizontalAlignment="Center"
                   Foreground="Aquamarine"
                   FontWeight="Bold"
                   FontSize="32"
                   Margin="0,0,0,20"/>
        <Button Grid.Row="1" Name="Api"
                Content="Получить данные"
                Background="Beige"
                Foreground="RosyBrown"
                Margin="5,0,5,0"/>
        <Button Grid.Row="2" Name="Api2"
                Content="Отправить результат"
                Background="Beige"
                Foreground="RosyBrown"
                Margin="5,10,5,0"/>
    </Grid>
</Window>
