<Window x:Class="CarharingApp.Views.AuthPage"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:CarharingApp.Views"
        mc:Ignorable="d"
        Title="Авторизация" Height="650" Width="500"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResize"
        Background="AliceBlue">
    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="auto"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <StackPanel Grid.Row="0" Margin="0,0,0,20">
            <TextBlock Text="CARSHERING" FontSize="32"
                       FontWeight="Bold"
                       HorizontalAlignment="Center"
                       Foreground="Aquamarine"/>
            <TextBlock Text="Вход в систему"
                       FontSize="15"
                       HorizontalAlignment="Center"
                       Foreground="Black"
                       Margin="0,5,0,0"/>
        </StackPanel>
        <StackPanel Grid.Row="1" Margin="0,0,0,15">
            <TextBlock Text="Логин"
                       FontWeight="Bold"
                       Foreground="Aquamarine"/>
            <TextBox Name="LoginTextBox"
                     Height="40"
                     Padding="10"
                     FontSize="14"/>
        </StackPanel>
        <StackPanel Grid.Row="2" Margin="0,0,0,25">
            <TextBlock Text="Пароль"
                       FontWeight="Bold"
                       Foreground="Aquamarine"/>
            <PasswordBox Name="PasswordBox"
                     Height="40"
                     Padding="10"
                     FontSize="14"/>
        </StackPanel>
        <Button Name="LoginButton"
            Grid.Row="3" 
            Content="Войти"
            Background="Beige"
            Foreground="RosyBrown"
                Margin="5"/>
        <Button Name="ChangePassword" Grid.Row="4"
                Margin="5,7,5,0"
                Content="Забыл пароль"
                Background="Beige"
                Foreground="RosyBrown"/>
    </Grid>

</Window>
